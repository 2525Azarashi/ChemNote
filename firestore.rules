rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner(docData) {
      return isAuthenticated() && request.auth.uid == docData.uid;
    }

    // ===============================================================
    // Collections
    // ===============================================================
    
    // ユーザープロフィール
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // 個人ノート
    match /notes/{noteId} {
      allow read: if isDocOwner(resource.data);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner(resource.data) && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner(resource.data);
    }

    // ============================================================
    // ランキング（リーダーボード）
    // ============================================================
    // 章ごとのベストスコア。
    //   ドキュメントID = `${chapterId}_${uid}`
    //   - 誰でも読める（順位表表示のため）
    //   - 書き込みは「自分の uid を含むドキュメント」かつ「自分のスコアのみ」可
    //   - bestScore が数値かつ過大でないことを軽くチェック（クライアント不正対策）
    match /leaderboard_chapter/{docId} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.bestScore is number
        && request.resource.data.bestScore >= 0
        && request.resource.data.bestScore <= 1000000;
      allow delete: if false;
    }

    // 全章合計スコア。ドキュメントID = uid
    match /leaderboard_total/{uid} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.totalScore is number
        && request.resource.data.totalScore >= 0
        && request.resource.data.totalScore <= 100000000;
      allow delete: if false;
    }

    // プレイ履歴（週間/月間ランキング集計用）。任意ドキュメントID。
    //   - 誰でも読める
    //   - 作成は本人のみ。更新・削除は不可（履歴の改ざん防止）
    match /leaderboard_events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000;
      allow update, delete: if false;
    }


    // Googleログインユーザー向けフレンド機能
    match /friend_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string;
      allow delete: if isAuthenticated()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow update: if false;
    }

    match /friends/{userId}/items/{friendUid} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated()
        && (request.auth.uid == userId || request.resource.data.uid == request.auth.uid);
      allow delete: if isAuthenticated()
        && (request.auth.uid == userId || friendUid == request.auth.uid);
    }
  }
}
